# Database (shared with payment and key services)
# When running in Docker, use 'postgres' as the host (Docker service name)
# When running directly on host, use 'localhost'
DATABASE_URL=postgresql://platformpub:password@postgres:5432/platformpub

# Session — minimum 32 characters. Generate with: openssl rand -base64 48
SESSION_SECRET=<at-least-32-characters>

# Cookie signing secret (can be the same as SESSION_SECRET)
COOKIE_SECRET=<at-least-32-characters>

# Platform service keypair — same key used by payment + key services
# Used by the gateway for NIP-44 unwrapping (deriving conversation keys)
PLATFORM_SERVICE_PRIVKEY=<64 hex chars>

# Reader hash key — used to HMAC reader pubkeys in receipt events
# Generate with: openssl rand -hex 32
READER_HASH_KEY=<64 hex chars>

# Admin — comma-separated account UUIDs that can access /admin/* routes
# At launch, this is the founder's account ID
ADMIN_ACCOUNT_IDS=<uuid1>,<uuid2>

# Email provider: 'postmark', 'resend', or 'console' (dev default)
EMAIL_PROVIDER=console
# EMAIL_FROM=login@all.haus
# POSTMARK_API_KEY=...
# RESEND_API_KEY=...

# Stripe
STRIPE_SECRET_KEY=sk_test_...

# Internal service URLs
# When running in Docker, use service names (payment, keyservice, etc.)
# When running directly on host, use localhost
PAYMENT_SERVICE_URL=http://payment:3001
KEY_SERVICE_URL=http://keyservice:3002
BLOSSOM_URL=http://blossom:3003
KEY_CUSTODY_URL=http://key-custody:3004
PLATFORM_RELAY_WS_URL=ws://strfry:7777

# Internal service shared secret — must match key-custody's INTERNAL_SECRET
# Generate with: openssl rand -base64 32
INTERNAL_SECRET=<base64 secret>

# App URL — must be the FRONTEND URL (Next.js), not the gateway.
# Used for OAuth redirect URIs, Stripe redirects, CORS origin, and magic links.
# Dev: http://localhost:3010  |  Prod: https://all.haus
APP_URL=http://localhost:3010

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Google OAuth (for "Sign in with Google")
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
