# Gateway URL — server-side only (used by Next.js SSR to proxy API requests)
# In Docker: use the Docker service name. On host: use localhost.
GATEWAY_URL=http://gateway:3000

# Public env vars (available to the browser via NEXT_PUBLIC_ prefix)
# These must use localhost — they resolve in the user's browser, not inside Docker.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
NEXT_PUBLIC_RELAY_URL=ws://localhost:4848
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
